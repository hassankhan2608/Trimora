# Trimora environment example.
# Copy to .env and fill values. .env is gitignored.

# Server
PORT=8080
BASE_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:5173

# Database
# Option A — local Postgres via docker compose --profile local-db
# DATABASE_URL=postgres://trimora:trimora@db:5432/trimora?sslmode=disable
#
# Option B — Supabase (use the direct, non-pooling connection string).
#   sslmode=require is mandatory.
#   Trimora opens persistent connections and runs CREATE TABLE on boot,
#   which works best on the direct port (5432), not the pgbouncer pooler (6543).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Web (Vite)
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:8080
